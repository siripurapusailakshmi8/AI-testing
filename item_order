from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
import time

# Setup WebDriver
driver = webdriver.Chrome()
driver.maximize_window()

try:
    # Step 1: Open Website
    driver.get("https://www.saucedemo.com/")
    time.sleep(2)

    # Step 2: Login
    driver.find_element(By.ID, "user-name").send_keys("standard_user")
    driver.find_element(By.ID, "password").send_keys("secret_sauce")
    driver.find_element(By.ID, "login-button").click()
    time.sleep(2)

    # Step 3: Add to Cart
    driver.find_element(By.ID, "add-to-cart-sauce-labs-backpack").click()
    print("Product added to cart")
    time.sleep(2)

    # Step 4: Go to Cart
    driver.find_element(By.CLASS_NAME, "shopping_cart_link").click()
    time.sleep(2)

    # Step 5: Checkout
    driver.find_element(By.ID, "checkout").click()
    time.sleep(2)

    # Step 6: Enter Checkout Details
    driver.find_element(By.ID, "first-name").send_keys("Sai")
    driver.find_element(By.ID, "last-name").send_keys("Lakshmi")
    driver.find_element(By.ID, "postal-code").send_keys("500010")
    driver.find_element(By.ID, "continue").click()
    time.sleep(2)

    # Step 7: Finish Order
    driver.find_element(By.ID, "finish").click()
    time.sleep(2)

    # Step 8: Order Confirmation Validation
    confirmation_text = driver.find_element(By.CLASS_NAME, "complete-header").text

    if "Thank you for your order!" in confirmation_text:
        print("Order placed successfully!")
    else:
        print("Order failed!")

    time.sleep(3)

except Exception as e:
    print("Error occurred:", e)

finally:
    driver.quit()
